entrypoint = "public/index.html"
modules = ["nodejs-20", "web"]

[nix]
channel = "stable-25_05"
packages = ["static-web-server", "supabase-cli"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = """
echo "Serving ./public via static-web-server on port 3000"
static-web-server -w ./.config/static-web-server.toml
"""
waitForPort = 3000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 80

[deployment]
publicDir = "public"
deploymentTarget = "static"

[agent]
expertMode = true
