entrypoint = "index.html"
modules = ["nodejs-20", "web"]

[nix]
channel = "stable-25_05"
packages = ["static-web-server", "unzip"]

# Run command used by the Run button
run = ["static-web-server", "-p", "3000", "-w", "./static-web-server.toml", "--root", "./"]

# Expose internal 3000 to external 80 (so Preview/browser works reliably)
[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "static"
publicDir = "."

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "SIRE App"

[[workflows.workflow]]
name = "SIRE App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "static-web-server --config-file static-web-server.toml"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
